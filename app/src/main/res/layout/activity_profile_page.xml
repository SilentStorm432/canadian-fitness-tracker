<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/profileImage"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        android:background="@drawable/circle"
        android:clipToOutline="true"
        android:src="@drawable/jeffy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/profileUsername"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:hint="Username"
        app:layout_constraintStart_toEndOf="@id/profileImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/profileImage" />

    <EditText
        android:id="@+id/profilePasword"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:hint="Password"
        app:layout_constraintStart_toEndOf="@id/profileImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profileUsername"/>

    <EditText
        android:id="@+id/profileHeight"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:hint="Height"
        app:layout_constraintStart_toEndOf="@id/profileImage"
        app:layout_constraintEnd_toStartOf="@id/profileSex"
        app:layout_constraintTop_toBottomOf="@id/profilePasword"
        app:layout_constraintHorizontal_weight="1"/>

    <EditText
        android:id="@+id/profileSex"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:hint="Sex"
        app:layout_constraintStart_toEndOf="@id/profileHeight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profilePasword"
        app:layout_constraintHorizontal_weight="1"/>

    <EditText
        android:id="@+id/profileWeight"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:hint="Weight"
        app:layout_constraintStart_toEndOf="@id/profileImage"
        app:layout_constraintEnd_toStartOf="@id/profileSex"
        app:layout_constraintTop_toBottomOf="@id/profileHeight"
        app:layout_constraintHorizontal_weight="1"/>

    <EditText
        android:id="@+id/profileBMI"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:hint="BMI"
        app:layout_constraintStart_toEndOf="@id/profileHeight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profileSex"
        app:layout_constraintHorizontal_weight="1"/>



</androidx.constraintlayout.widget.ConstraintLayout>